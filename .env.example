# ─── Bharat Lens – Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your actual keys.
# Never commit .env to Git.

# OpenAI API Key (for embeddings + GPT-4o Mini)
VITE_OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# Pinecone – API Key from your Pinecone console
VITE_PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE

# Pinecone – Index Host URL (from index details in Pinecone console)
# Format: https://scheme-data-xxxxxxx.svc.us-east-1-aws.pinecone.io
VITE_PINECONE_HOST=https://YOUR_INDEX_HOST_HERE.pinecone.io
